{
  "info": {
    "_postman_id": "78579f9e-3904-4735-820e-4148dd78fa02",
    "name": "d&d spells tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "53398917",
