              "    }\r",
              "    else {\r",
              "        pm.expect.fail(`Categoria de armadura desconhecida: ${categoria}`);\r",
              "    }\r",
              "});\r",
              "\r",
              "pm.test(\"Tempo de resposta é menos de 1s\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
