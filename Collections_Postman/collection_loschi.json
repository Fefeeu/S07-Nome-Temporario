              "    pm.expect(resposta.equipment_category.name).to.equal(\"Armor\");\r",
              "    pm.expect(resposta.equipment_category.url).to.equal(\"/api/2014/equipment-categories/armor\");\r",
              "});\r",
              "pm.test(\"Desvantagem em stealth condiz com o tipo de armadura\", function(){\r",
              "    const resposta = pm.response.json();\r",
              "    const categoria = resposta.armor_category;\r",
              "    if(categoria === \"Heavy\"){\r",
              "        pm.expect(resposta.stealth_disadvantage).to.equal(true);\r",
              "    }\r",
              "    else if(categoria === \"Light\"){\r",
