  "item": [
    {
      "name": "Basket",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Equipamento Basket possui campos obrigatorios\", function(){\r",
              "    const resposta = pm.response.json();\r",
              "    pm.expect(resposta.name).to.equal(\"Basket\");\r",
              "    pm.expect(resposta.index).to.equal(\"basket\");\r",
              "    pm.expect(resposta.url).to.equal(\"/api/2014/equipment/basket\")\r",
              "    pm.expect(resposta.equipment_category).that.is.not.empty;\r",
              "});\r",
              "\r",
              "pm.test(\"Campo cost possui tipos corretos\", function(){\r",
              "    const resposta = pm.response.json();\r",
              "    pm.expect(resposta.cost.quantity).to.be.a(\"number\");\r",
              "    pm.expect(resposta.cost.unit).to.be.a(\"string\");\r",
              "});\r",
              "\r",
              "pm.test(\"Arma deve possuir categoria de arma\", function(){\r",
              "    const resposta = pm.response.json();\r",
              "    pm.expect(resposta.equipment_category.index).to.equal(\"adventuring-gear\");\r",
              "    pm.expect(resposta.equipment_category.name).to.equal(\"Adventuring Gear\");\r",
              "    pm.expect(resposta.equipment_category.url).to.equal(\"/api/2014/equipment-categories/adventuring-gear\");\r",
              "    \r",
              "});\r",
              "\r",
              "pm.test(\"Weight deve ser um numero maior que zero\", function(){\r",
              "    const resposta = pm.response.json();\r",
              "    const valor = resposta.weight;\r",
              "    pm.expect(resposta.weight).to.be.a(\"number\");\r",
              "    pm.expect(valor).above(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Tempo de resposta é menos de 1s\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
              "});    "
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseURL}}/equipment/basket",
          "host": [
            "{{baseURL}}"
          ],
          "path": [
